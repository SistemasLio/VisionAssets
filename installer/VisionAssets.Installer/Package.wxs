<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
      Name="VisionAssets Agent"
      Manufacturer="Sistemas Lio"
      Version="0.5.0.0"
      Language="1046"
      Scope="perMachine"
      InstallerVersion="500"
      UpgradeCode="A3F8E2B1-4C5D-4E7F-8091-A2B3C4D5E6F7">
    <SummaryInformation Description="Agente de inventário VisionAssets (hardware e software)." />

    <MajorUpgrade DowngradeErrorMessage="Já está instalada uma versão mais recente do VisionAssets Agent." />
    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <Feature Id="MainFeature" Title="VisionAssets Agent" Level="1">
      <ComponentGroupRef Id="AgentComponents" />
    </Feature>

    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="CompanyFolder" Name="VisionAssets">
        <Directory Id="INSTALLFOLDER" Name="Agent" />
      </Directory>
    </StandardDirectory>

    <ComponentGroup Id="AgentComponents" Directory="INSTALLFOLDER">
      <Component Id="AgentService" Guid="B7E4A1C2-9D3E-4F80-B5A6-123456789ABC">
        <File
            Id="AgentExe"
            Source="!(bindpath.Payload)\VisionAssets.Agent.exe"
            KeyPath="yes" />
        <ServiceInstall
            Id="SvcInstall"
            Name="VisionAssets Agent"
            DisplayName="VisionAssets Agent"
            Description="Inventário local de hardware e software (VisionAssets)."
            Type="ownProcess"
            Start="auto"
            ErrorControl="normal" />
        <ServiceControl
            Id="SvcControl"
            Name="VisionAssets Agent"
            Start="install"
            Stop="both"
            Remove="uninstall"
            Wait="yes" />
      </Component>
      <Files Include="!(bindpath.Payload)\*.dll" />
      <Files Include="!(bindpath.Payload)\*.json" />
    </ComponentGroup>
  </Package>
</Wix>
